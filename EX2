<!DOCTYPE html>
<html>
<head>
<title>Shopping Cart & Checkout</title>
</head>
<body style="background-color:pink";>
<section id="shopping-cart">
<center>
<h2>Your Shopping Cart</h2>
</center>
<table border="1" width="100%">
<tr>
<th>Product</th>
<th>Price</th>
<th>Quantity</th>
<th>Total</th>
<th>Action</th>
</tr>
<tbody>
<tr>
<td>Barbie doll</td>
<td>500.0</td>
<td>

<input type="number" value="1" min="1" max="10">
</td>
<td>$500.0</td>
<td><button type="button">Remove</button></td>
</tr>
</tbody>
</table>
<div id="cart-summary">
<p><strong>Subtotal:</strong> 500.00</p>
<p><strong>Shipping:</strong> Free</p>
<h3><strong>Grand Total:</strong> 500.00</h3>
</div>
</section>
<hr>
<section id="checkout-payment">
<h2>Secure Payment</h2>
<form>
<fieldset>
<legend>Billing Information</legend>
<p>
<label for="full-name">Full Name:</label>
<input type="text" id="full-name" name="fullName" required placeholder="Enter Name">
</p>
<p>
<label for="email">Email Address:</label>
<input type="email" id="email" name="email" required placeholder="Enter Email">
</p>

</fieldset>
<fieldset>
<legend>Credit or Debit Card</legend>
<p>
<label for="card-num">Card Number:</label>
<input type="text" id="card-num" name="cardNumber" required pattern="\d{16}" placeholder="1234567812345678" maxlength="16">
</p>
<p>
<label for="cvv">CVV:</label>
<input type="password" id="cvv" name="cardCVV" required pattern="\d{3,4}" placeholder="123" maxlength="4">
</p>
</fieldset>
<!-- Submit Action -->
<p>
<button type="submit">Pay Now</button>
</p>
</form>
</section>
</body>
</html>


